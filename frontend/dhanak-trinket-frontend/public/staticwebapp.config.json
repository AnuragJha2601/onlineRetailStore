{
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": [
            "/images/*.{png,jpg,gif,ico}",
            "/_next/*",
            "/favicon.ico",
            "/sitemap.xml",
            "/robots.txt"
        ]
    },
    "routes": [
        {
            "route": "/admin",
            "rewrite": "/admin/index.html"
        }
    ],
    "mimeTypes": {
        ".json": "text/json",
        ".xml": "application/xml"
    }
}